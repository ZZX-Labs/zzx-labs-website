{
  "schema_version": 3,
  "default": "zzx",
  "order": [
    "zzx",
    "coinbase",
    "kraken",
    "gemini",
    "bitstamp",
    "bitfinex",
    "okx",
    "crypto_com",
    "kucoin",
    "gateio",
    "bitget",
    "mexc",
    "htx",
    "binance_us"
  ],
  "sources": {
    "zzx": {
      "label": "ZZX Global BPI",
      "url": "/bitcoin/bpi/api/latest.json",
      "parser": "zzx_bpi",
      "kind": "computed"
    },
    "coinbase": {
      "label": "Coinbase",
      "url": "https://api.exchange.coinbase.com/products/BTC-USD/stats",
      "parser": "coinbase_stats",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange"
    },
    "kraken": {
      "label": "Kraken",
      "url": "https://api.kraken.com/0/public/Ticker?pair=XBTUSD",
      "parser": "kraken_ticker",
      "pair": "XBT-USD",
      "fallback": "coingecko_exchange"
    },
    "gemini": {
      "label": "Gemini",
      "url": "https://api.gemini.com/v1/pubticker/btcusd",
      "parser": "gemini_pubticker",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange"
    },
    "bitstamp": {
      "label": "Bitstamp",
      "url": "https://www.bitstamp.net/api/v2/ticker/btcusd/",
      "parser": "bitstamp_ticker",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange",
      "cors_proxy": true
    },
    "bitfinex": {
      "label": "Bitfinex",
      "url": "https://api-pub.bitfinex.com/v2/ticker/tBTCUSD",
      "parser": "bitfinex_v2_ticker",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange",
      "cors_proxy": true
    },
    "okx": {
      "label": "OKX",
      "url": "https://www.okx.com/api/v5/market/ticker?instId=BTC-USDT",
      "parser": "okx_ticker",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "crypto_com": {
      "label": "Crypto.com",
      "url": "https://api.crypto.com/v2/public/get-ticker?instrument_name=BTC_USD",
      "parser": "crypto_com_ticker",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange"
    },
    "kucoin": {
      "label": "KuCoin",
      "url": "https://api.kucoin.com/api/v1/market/stats?symbol=BTC-USDT",
      "parser": "kucoin_stats",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "gateio": {
      "label": "Gate.io",
      "url": "https://api.gateio.ws/api/v4/spot/tickers?currency_pair=BTC_USDT",
      "parser": "gateio_ticker",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "bitget": {
      "label": "Bitget",
      "url": "https://api.bitget.com/api/v2/spot/market/tickers?symbol=BTCUSDT",
      "parser": "bitget_ticker",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "mexc": {
      "label": "MEXC",
      "url": "https://api.mexc.com/api/v3/ticker/24hr?symbol=BTCUSDT",
      "parser": "mexc_24hr",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "htx": {
      "label": "HTX",
      "url": "https://api.huobi.pro/market/detail/merged?symbol=btcusdt",
      "parser": "htx_merged",
      "pair": "BTC-USDT",
      "fallback": "coingecko_exchange"
    },
    "binance_us": {
      "label": "Binance US",
      "url": "https://api.binance.us/api/v3/ticker/24hr?symbol=BTCUSD",
      "parser": "binance_24hr",
      "pair": "BTC-USD",
      "fallback": "coingecko_exchange"
    }
  },
  "disabled_sources": {
    "okcoin": {
      "label": "OKCoin",
      "reason": "Legacy endpoint unstable/deprecated. Re-add after a confirmed public BTC-USD ticker endpoint is selected."
    },
    "coingecko_global": {
      "label": "CoinGecko Global",
      "reason": "Global aggregate must never be counted as an exchange source because it double-counts exchanges."
    }
  },
  "coingecko_exchange_ids": {
    "coinbase": [
      "coinbase_exchange"
    ],
    "kraken": [
      "kraken"
    ],
    "gemini": [
      "gemini"
    ],
    "bitstamp": [
      "bitstamp"
    ],
    "bitfinex": [
      "bitfinex"
    ],
    "okx": [
      "okx"
    ],
    "crypto_com": [
      "crypto_com"
    ],
    "kucoin": [
      "kucoin"
    ],
    "gateio": [
      "gate"
    ],
    "bitget": [
      "bitget"
    ],
    "mexc": [
      "mxc"
    ],
    "htx": [
      "huobi"
    ],
    "binance_us": [
      "binance_us"
    ]
  },
  "weighting": {
    "supply_basis": "mined_supply_to_date",
    "formula": "weight_i=(volume_24h_btc_i/mined_supply_btc)/sum(volume_24h_btc/mined_supply_btc); bpi=sum(price_usd_i*weight_i)",
    "coingecko_policy": "CoinGecko may only be used as per-exchange fallback. No CoinGecko global aggregate is allowed as a source."
  }
}
